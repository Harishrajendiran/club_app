# Flask Configuration
FLASK_SECRET_KEY=generate_a_random_hex_string_here
FLASK_ENV=production

# Database Configuration (for PythonAnywhere, host is usually username.mysql.pythonanywhere-services.com)
MYSQL_HOST=yourusername.mysql.pythonanywhere-services.com
MYSQL_USER=yourusername
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=yourusername$badminton_tournament
MYSQL_PORT=3306
